Project 2: AI Agent with Tool Use (Month 5)
python# Don't use LangChain for this one.
# Build your own lightweight agent to show you understand the pattern.

class ReActAgent:
    def __init__(self, llm, tools: dict):
        self.llm = llm
        self.tools = tools  # {"web_search": fn, "calculator": fn}
        self.scratchpad = []
    
    def run(self, query: str) -> str:
        while True:
            # Thought → Action → Observation loop
            response = self.llm.complete(
                self._build_prompt(query, self.scratchpad)
            )
            action = self._parse_action(response)
            
            if action.type == "FINISH":
                return action.result
            
            # Execute tool
            observation = self.tools[action.name](action.input)
            self.scratchpad.append((action, observation))
